rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Catch-all (Deny by default)
    match /{document=**} {
      allow read, write: if false;
    }

    // Standard Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function existing() {
      return resource.data;
    }

    function incoming() {
      return request.resource.data;
    }

    // Check if user is admin
    // 1. Hardcoded email check for root admin
    // 2. Firestore role check
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'davedotgordon@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Users Collection
    match /users/{userId} {
      // Users can read any profile (needed for directory/admin management list)
      // Actually, standard users only need to read their own or admins read all.
      // But for the 'Manage Admins' list, admins need to read all.
      allow read: if isSignedIn();
      
      // Users can only create their own profile
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      // Role updates are restricted to Admins only
      allow update: if isSignedIn() && (
        // Root admin can do anything
        request.auth.token.email == 'davedotgordon@gmail.com' ||
        // User updating their own NON-role fields
        (request.auth.uid == userId && !incoming().diff(existing()).affectedKeys().hasAny(['role'])) ||
        // Admin updating role of others (but cannot revoke root admin)
        (isAdmin() && (existing().email != 'davedotgordon@gmail.com' || incoming().role == 'admin'))
      );
    }

    // Families Collection
    match /families/{familyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid in existing().memberUids)
      );
      allow delete: if isAdmin();
    }

    // Invites & Codes
    match /invites/{inviteId} {
      // Allow public lookup of codes for new member registration
      allow read: if true;
      allow write: if isAdmin();
    }

    match /invite_codes/{codeId} {
      // Allow public lookup of family codes
      allow read: if true; 
      allow write: if isAdmin();
    }

    // Requests
    match /requests/{requestId} {
      allow create: if true; // Public contact form
      allow read, update, delete: if isAdmin();
    }
  }
}
